        paid as paid_classes,
        higher as wants_higher_ed,
        internet as has_internet,

        -- lifestyle
        famrel as family_relationship,
        freetime,
        goout,
        dalc as weekday_alcohol,
        walc as weekend_alcohol,
        health,
        romantic,

        -- target variable
        case when g3 < 10 then 1 else 0 end as at_risk

    from source
)

select * from staged
  );
